                    <tr class="w3-blue">
                        <th>ID</th>
                        <th>Инвентарный номер</th>
                        <th>Модель / марка</th>
                        <th>Тип</th>
                        <th>Отдел</th>
                        <th>Ответственный</th>
                        <th>Дата ввода</th>
                    </tr>
                </thead>
                <tbody>
                    {% for computer in computers %}
                        <tr>
                            <td>{{ computer.id }}</td>
                            <td>{{ computer.inventory_number }}</td>
                            <td>{{ computer.model }}</td>
                            <td>{{ computer.computer_type }}</td>
                            <td>{{ computer.department }}</td>
                            <td>{{ computer.responsible_employee }}</td>
                            <td>{{ computer.commissioning_date }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>Записей пока нет.</p>
        {% endif %}
    </div>
</div>

</body>
</html>
